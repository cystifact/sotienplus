rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // All writes go through tRPC (server-side Admin SDK)
    // Firestore rules only need to allow reads for authenticated users

    // Helper: get the requesting user's role
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    match /users/{userId} {
      // Own profile: any authenticated user; other profiles: admin or manager only
      allow read: if request.auth != null
                    && (request.auth.uid == userId
                        || getUserRole() in ['admin', 'manager']);
      allow write: if false;
    }

    match /cash_records/{recordId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /customers/{customerId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /collectors/{collectorId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /settings/{settingId} {
      // Contains API credentials — admin only
      allow read: if request.auth != null
                    && getUserRole() == 'admin';
      allow write: if false;
    }

    // Deny all other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
